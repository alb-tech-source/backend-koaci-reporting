{
  "functions": {
    "api/index.ts": {
      "includeFiles": "node_modules/swagger-ui-dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/api-docs",
      "destination": "/api-docs"
    },
    {
      "source": "/api-docs/(.*)",
      "destination": "/api-docs/$1"
    }
  ],
  "headers": [
    {
      "source": "/api-docs/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
